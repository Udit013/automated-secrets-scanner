# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///./secrets_scanner.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/secrets_scanner

# GitHub API token (free — increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Email notifications (optional — leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Backend URL (used in emails)
BACKEND_URL=http://localhost:8000
